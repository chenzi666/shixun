<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.glw.mapper.FoodMapper">
    
    <resultMap id="FoodResultMap" type="org.example.glw.entity.Food">
        <id column="food_id" property="foodId"/>
        <result column="name" property="name"/>
        <result column="description" property="description"/>
        <result column="restaurant_name" property="restaurantName"/>
        <result column="price" property="price"/>
        <result column="images" property="images"/>
        <result column="score" property="score"/>
        <result column="view_count" property="viewCount"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="category_id" property="categoryId"/>
    </resultMap>
    
    <sql id="foodColumns">
        food_id, name, description, restaurant_name, price, images, score, view_count, status, create_time, update_time, category_id
    </sql>
    
    <select id="selectFoods" resultMap="FoodResultMap">
        SELECT <include refid="foodColumns"/>
        FROM food
        <where>
            status = 1
            <if test="categoryId != null">
                AND category_id = #{categoryId}
            </if>
            <if test="keyword != null and keyword != ''">
                AND (name LIKE CONCAT('%', #{keyword}, '%') OR description LIKE CONCAT('%', #{keyword}, '%') OR restaurant_name LIKE CONCAT('%', #{keyword}, '%'))
            </if>
        </where>
        <choose>
            <when test="sort != null and sort != '' and order != null and order != ''">
                ORDER BY ${sort} ${order}
            </when>
            <otherwise>
                ORDER BY food_id DESC
            </otherwise>
        </choose>
        LIMIT #{offset}, #{size}
    </select>
    
    <select id="countFoods" resultType="java.lang.Long">
        SELECT COUNT(*) FROM food
        <where>
            status = 1
            <if test="categoryId != null">
                AND category_id = #{categoryId}
            </if>
            <if test="keyword != null and keyword != ''">
                AND (name LIKE CONCAT('%', #{keyword}, '%') OR description LIKE CONCAT('%', #{keyword}, '%') OR restaurant_name LIKE CONCAT('%', #{keyword}, '%'))
            </if>
        </where>
    </select>
    
    <select id="selectById" resultMap="FoodResultMap">
        SELECT <include refid="foodColumns"/>
        FROM food
        WHERE food_id = #{foodId} AND status = 1
    </select>
</mapper>