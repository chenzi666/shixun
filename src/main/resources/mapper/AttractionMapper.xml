<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.glw.mapper.AttractionMapper">
    
    <resultMap id="AttractionResultMap" type="org.example.glw.entity.Attraction">
        <id column="attraction_id" property="attractionId"/>
        <result column="name" property="name"/>
        <result column="description" property="description"/>
        <result column="address" property="address"/>
        <result column="phone" property="phone"/>
        <result column="opening_hours" property="openingHours"/>
        <result column="ticket_price" property="ticketPrice"/>
        <result column="images" property="images"/>
        <result column="video_url" property="videoUrl"/>
        <result column="longitude" property="longitude"/>
        <result column="latitude" property="latitude"/>
        <result column="score" property="score"/>
        <result column="view_count" property="viewCount"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="category_id" property="categoryId"/>
    </resultMap>
    
    <sql id="attractionColumns">
        attraction_id, name, description, address, phone, opening_hours, ticket_price, 
        images, video_url, longitude, latitude, score, view_count, status, create_time, update_time, category_id
    </sql>
    
    <select id="selectAttractions" resultMap="AttractionResultMap">
        SELECT <include refid="attractionColumns"/>
        FROM attraction
        <where>
            status = 1
            <if test="categoryId != null">
                AND category_id = #{categoryId}
            </if>
            <if test="keyword != null and keyword != ''">
                AND (name LIKE CONCAT('%', #{keyword}, '%') OR description LIKE CONCAT('%', #{keyword}, '%'))
            </if>
        </where>
        <choose>
            <when test="sort != null and sort != '' and order != null and order != ''">
                ORDER BY ${sort} ${order}
            </when>
            <otherwise>
                ORDER BY attraction_id DESC
            </otherwise>
        </choose>
        LIMIT #{offset}, #{size}
    </select>
    
    <select id="countAttractions" resultType="java.lang.Long">
        SELECT COUNT(*) FROM attraction
        <where>
            status = 1
            <if test="categoryId != null">
                AND category_id = #{categoryId}
            </if>
            <if test="keyword != null and keyword != ''">
                AND (name LIKE CONCAT('%', #{keyword}, '%') OR description LIKE CONCAT('%', #{keyword}, '%'))
            </if>
        </where>
    </select>
    
    <select id="selectById" resultMap="AttractionResultMap">
        SELECT <include refid="attractionColumns"/>
        FROM attraction
        WHERE attraction_id = #{attractionId} AND status = 1
    </select>
</mapper>