<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.glw.mapper.admin.AdminUserMapper">

    <!-- 查询用户列表 -->
    <select id="selectUsers" resultType="org.example.glw.entity.User">
        SELECT user_id, username, nickname, email, phone, role_id, status, register_time
        FROM users
        <where>
            <if test="username != null and username != ''">
                AND username LIKE CONCAT('%', #{username}, '%')
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
        </where>
        ORDER BY register_time DESC
        LIMIT #{offset}, #{size}
    </select>

    <!-- 查询用户总数 -->
    <select id="countUsers" resultType="java.lang.Long">
        SELECT COUNT(*) FROM users
        <where>
            <if test="username != null and username != ''">
                AND username LIKE CONCAT('%', #{username}, '%')
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
        </where>
    </select>

    <!-- 更新用户信息 -->
    <update id="updateById" parameterType="org.example.glw.entity.User">
        UPDATE users
        <set>
            <if test="status != null">
                status = #{status},
            </if>
        </set>
        WHERE user_id = #{userId}
    </update>

</mapper>